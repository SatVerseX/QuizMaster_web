{
  "version": "1.0.0",
  "name": "QuizMaster Professional Theme",
  "description": "Professional light theme configuration for QuizMaster React application",
  "$themes": [
    {
      "name": "light",
      "type": "light",
      "default": true,
      "selectedTokenSets": {
        "global": "enabled",
        "semantic": "enabled",
        "components": "enabled"
      }
    },
    {
      "name": "dark",
      "type": "dark",
      "default": false,
      "selectedTokenSets": {
        "global": "enabled",
        "semantic-dark": "enabled",
        "components-dark": "enabled"
      }
    }
  ],
  "$metadata": {
    "tokenSetOrder": ["global", "semantic", "components"],
    "activeThemes": ["light"],
    "activeSets": ["global", "semantic", "components"]
  },
